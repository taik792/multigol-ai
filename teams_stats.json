import requests
import json
import os

API_KEY = os.getenv("API_KEY")

headers = {
    "x-apisports-key": API_KEY
}

with open("data/matches.json") as f:
    matches = json.load(f)

teams = set()

for match in matches:
    teams.add(match["home"])
    teams.add(match["away"])

stats = {}

for team in teams:

    url = "https://v3.football.api-sports.io/teams/statistics"

    params = {
        "league": 39,
        "season": 2025,
        "team": team
    }

    response = requests.get(url, headers=headers, params=params)

    data = response.json()

    if "response" not in data:
        continue

    try:
        played = data["response"]["fixtures"]["played"]["total"]

        if played == 0:
            continue

        goals_for = data["response"]["goals"]["for"]["total"]["total"]
        goals_against = data["response"]["goals"]["against"]["total"]["total"]

        stats[team] = {
            "goals_scored": goals_for / played,
            "goals_conceded": goals_against / played
        }

    except:
        continue

os.makedirs("data", exist_ok=True)

with open("data/team_stats.json", "w") as f:
    json.dump(stats, f)

print("Statistiche squadre aggiornate:", len(stats))